# LMS Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://lms-mongo:27017/lms

# ML Service URL (internal Docker network)
ML_SERVICE_URL=http://lms-ml:8000

# JWT
JWT_SECRET=change-this-in-production

# SMTP (optional: required only if email notifications are enabled)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=your-password
SMTP_FROM=LMS Portal <no-reply@example.com>
