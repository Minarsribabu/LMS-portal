# LMS Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://lms-mongo:27017/lms

# ML Service URL (internal Docker network)
ML_SERVICE_URL=http://lms-ml:8000

# JWT
JWT_SECRET=change-this-in-production

# SMTP (email notifications)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=LMS Portal <no-reply@example.com>

# Backward-compatible SMTP aliases
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=LMS Portal <no-reply@example.com>
