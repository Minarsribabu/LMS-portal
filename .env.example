# ─────────────────────────────────────────────
# LMS Portal — Environment Variables
# Copy to .env and fill in production values
# ─────────────────────────────────────────────

# ── Backend ──
PORT=5000
MONGO_URI=mongodb://lms-mongo:27017/lms
ML_SERVICE_URL=http://lms-ml:8000

# ── Grafana ──
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Docker Hub (for CI/CD) ──
DOCKER_USERNAME=yourdockerhub

# ── Server (for CI/CD deploy) ──
SERVER_HOST=your-server-ip
SERVER_USER=ubuntu
